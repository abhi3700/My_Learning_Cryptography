      "frameId": null,
      "index": "b1M",
      "roundness": null,
      "seed": 1243132527,
      "version": 777,
      "versionNonce": 699293441,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1775123979089,
      "link": null,
      "locked": false,
      "text": "➤ OR\nc = a + b - a . b\n\nEnforce:\na . (a - 1) = 0\nb . (b - 1) = 0\nc . (c - 1) = 0\na . b = a + b - c\n\n👉 fits R1CS",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "middle",
      "containerId": "m2Cw91kLXjbuuwhNiu9WQ",
      "originalText": "➤ OR\nc = a + b - a . b\n\nEnforce:\na . (a - 1) = 0\nb . (b - 1) = 0\nc . (c - 1) = 0\na . b = a + b - c\n\n👉 fits R1CS",
      "autoResize": true,
      "lineHeight": 1.25
