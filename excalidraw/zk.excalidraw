    },
    {
      "id": "xmORWkOarFV-Jf3SSsAnb",
      "type": "text",
      "x": 7116.502345064425,
      "y": 1833.5811448032491,
      "width": 134.41993713378906,
      "height": 250,
      "angle": 0,
      "strokeColor": "#1e1e1e",
