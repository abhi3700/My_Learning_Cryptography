      "text": "(A . w) x (B . w) = (C . w)",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "center",
      "verticalAlign": "middle",
      "containerId": "b4T5tyijyHVfaVLdjDxcA",
      "originalText": "(A . w) x (B . w) = (C . w)",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "Ou-tJX8JBh9slqYD1H3_V",
      "type": "text",
      "x": 4977.148202230463,
      "y": 1156.687799452357,
      "width": 517.439453125,
      "height": 80,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [
        "M1cGR-bbYu9dbJ_M91vqp",
        "cXnbgRYJrSctIP4-1BUh3"
      ],
      "frameId": null,
      "index": "aH",
      "roundness": null,
      "seed": 1879207137,
      "version": 123,
      "versionNonce": 363291713,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1775113295505,
      "link": null,
      "locked": false,
      "text": "where:\n        w = vector of all variables (public + private + intermediates)\n        \".\" (dot) = dot product (linear combination)\n        \"x\" (cross) = normal multiplication in the field.",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
