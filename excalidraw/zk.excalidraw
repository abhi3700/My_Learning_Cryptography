    {
      "id": "b8ySz6XQ52TFf69z9vqlP",
      "type": "text",
      "x": 6626.484945383303,
      "y": 5446.712266873008,
      "width": 484.69952392578125,
      "height": 375,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#e9ecef",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [
        "6lahRFtup3ToXfQ-ooDii"
      ],
      "frameId": "FLBerPE-wVn8otL6LuGO3",
      "index": "b33",
      "roundness": null,
      "seed": 16007329,
      "version": 344,
      "versionNonce": 1584720211,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1775128648677,
      "link": null,
      "locked": false,
      "text": "For valid case:\n• encoded rule says y = x^2 + 3\n• assigned x = 5\n• synthesized t = 25, y = 28\n• public input is 28\n\nSo it passes.\n\nFor invalid case:\n• encoded rule still says y = x^2 + 3\n• assigned x = 5\n• synthesized y = 28\n• public input is 1024\n\nSo constrain_instance fails, and verification fails.",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "For valid case:\n• encoded rule says y = x^2 + 3\n• assigned x = 5\n• synthesized t = 25, y = 28\n• public input is 28\n\nSo it passes.\n\nFor invalid case:\n• encoded rule still says y = x^2 + 3\n• assigned x = 5\n• synthesized y = 28\n• public input is 1024\n\nSo constrain_instance fails, and verification fails.",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "d0veBHBbLRsAzkYV3QuMm",
      "type": "text",
      "x": 6597.84882106429,
      "y": 5014.879444812814,
      "width": 580.3196411132812,
      "height": 50,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#ffc9c9",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
