      "isDeleted": false,
      "boundElements": [],
      "updated": 1775123979089,
      "link": null,
      "locked": false,
      "text": "➤ AND\nc = a ∧ b\n\nEnforce:\na . (a - 1) = 0\nb . (b - 1) = 0\nc . (c - 1) = 0\na . b = c\n\n👉 fits R1CS",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "middle",
      "containerId": "UvLlSdy2nxJEOgcrd5Z_I",
      "originalText": "➤ AND\nc = a ∧ b\n\nEnforce:\na . (a - 1) = 0\nb . (b - 1) = 0\nc . (c - 1) = 0\na . b = c\n\n👉 fits R1CS",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "m2Cw91kLXjbuuwhNiu9WQ",
      "type": "rectangle",
      "x": 7291.9360332885835,
      "y": 1827.2081737628105,
      "width": 179.5297502239583,
      "height": 260,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [
        "stADCqPQTy-_QUcgICkzq",
        "ehB0f4EXskfdj38GFMfv8"
      ],
      "frameId": null,
      "index": "b1L",
      "roundness": null,
      "seed": 60953679,
      "version": 541,
      "versionNonce": 1505891183,
      "isDeleted": false,
