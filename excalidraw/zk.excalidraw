      "link": null,
      "locked": false,
      "text": "Multiplication constraints are enough because:\n• all computation = arithmetic\n• all arithmetic = polynomials\n• all polynomials can be enforced using multiplication of linear terms",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Multiplication constraints are enough because:\n• all computation = arithmetic\n• all arithmetic = polynomials\n• all polynomials can be enforced using multiplication of linear terms",
      "autoResize": true,
      "lineHeight": 1.25
    },
