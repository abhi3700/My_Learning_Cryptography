      "link": null,
      "locked": false
    },
    {
      "id": "BJ0idDJ2V04YWipR6lg5-",
      "type": "text",
      "x": 7296.9360332885835,
      "y": 1832.2081737628105,
      "width": 155.01992797851562,
      "height": 250,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [
        "stADCqPQTy-_QUcgICkzq",
        "ehB0f4EXskfdj38GFMfv8"
