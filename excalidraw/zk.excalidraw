      "link": null,
      "locked": false,
      "text": "Still, this is enough to express any program.\nWhy? —> Bcoz everything reduces to polynomials.",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
