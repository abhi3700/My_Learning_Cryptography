    {
      "id": "vLYF9QWQxXLxK3NPxT6Th",
      "type": "text",
      "x": 4654.112250853822,
      "y": 3396.348264107597,
      "width": 702.399658203125,
      "height": 175,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b2b",
      "roundness": null,
      "seed": 501569359,
      "version": 172,
      "versionNonce": 1706368463,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1775123178531,
      "link": null,
      "locked": false,
      "text": "Compute:\nA . w = [0, 1, 0, 0] . [1, 5, 25, 28] = 0 . 1 + 1 . 5 + 0 . 25 + 0 . 28 = 5\n\nB . w = [0, 1, 0, 0] . [1, 5, 25, 28] = 0 . 1 + 1 . 5 + 0 . 25 + 0 . 28 = 5\n\nC . w = [0, 0, 1, 0] . [1, 5, 25, 28] = 0 . 1 + 0 . 5 + 1 . 25 + 0 . 28 = 25\n",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Compute:\nA . w = [0, 1, 0, 0] . [1, 5, 25, 28] = 0 . 1 + 1 . 5 + 0 . 25 + 0 . 28 = 5\n\nB . w = [0, 1, 0, 0] . [1, 5, 25, 28] = 0 . 1 + 1 . 5 + 0 . 25 + 0 . 28 = 5\n\nC . w = [0, 0, 1, 0] . [1, 5, 25, 28] = 0 . 1 + 0 . 5 + 1 . 25 + 0 . 28 = 25\n",
      "autoResize": true,
      "lineHeight": 1.25
    },
