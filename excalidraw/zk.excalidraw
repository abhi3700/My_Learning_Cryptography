      "isDeleted": false,
      "boundElements": [],
      "updated": 1775128365518,
      "link": null,
      "locked": false,
      "text": "template SquarePlusThree() {\n    signal input x;\n    signal output y;\n\n    signal t;\n\n    t <== x * x;\n    y <== t + 3;\n}",
      "fontSize": 21.420233063634765,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "template SquarePlusThree() {\n    signal input x;\n    signal output y;\n\n    signal t;\n\n    t <== x * x;\n    y <== t + 3;\n}",
      "autoResize": true,
      "lineHeight": 1.25
    },
